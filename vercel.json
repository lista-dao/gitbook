{
  "version": 2,
  "builds": [
    {
      "src": "bot/bot.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/webhook",
      "dest": "/bot/bot.js",
      "methods": ["POST"]
    },
    {
      "src": "/",
      "dest": "/bot/bot.js",
      "methods": ["GET"]
    }
  ],
  "env": {
    "PINECONE_API_KEY": "@pinecone_api_key",
    "PINECONE_INDEX_NAME": "@pinecone_index_name",
    "BOT_TOKEN": "@bot_token",
    "OPENAI_API_KEY": "@openai_api_key"
  },
  "functions": {
    "bot/bot.js": {
      "maxDuration": 30
    }
  }
}
