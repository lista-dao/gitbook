{
  "name": "gitbook-rag-bot",
  "version": "1.0.0",
  "description": "GitBook RAG Bot with Telegram integration",
  "main": "bot/bot.js",
  "scripts": {
    "setup": "node scripts/setup-pinecone.js",
    "init": "node scripts/init.js",
    "sync": "node scripts/sync.js",
    "manual-sync:workflow": "node scripts/manual-sync.js --workflow",
    "manual-sync:test-all": "node scripts/manual-sync.js --test-all",
    "manual-sync:list": "node scripts/manual-sync.js --list-synced",
    "manual-sync:pending": "node scripts/manual-sync.js --list-pending",
    "start": "node bot/bot.js",
    "dev": "nodemon bot/bot.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop gitbook-rag-bot",
    "pm2:restart": "pm2 restart gitbook-rag-bot",
    "pm2:reload": "pm2 reload gitbook-rag-bot",
    "pm2:logs": "pm2 logs gitbook-rag-bot",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:delete": "pm2 delete gitbook-rag-bot",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^6.1.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "franc": "^6.2.0",
    "marked": "^9.1.6",
    "simple-git": "^3.20.0",
    "telegraf": "^4.15.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pm2": "^5.3.1"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "gitbook",
    "rag",
    "telegram",
    "bot",
    "pinecone",
    "embeddings"
  ],
  "author": "",
  "license": "MIT"
}
